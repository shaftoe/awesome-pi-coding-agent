{
  "branches": ["main"],
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits",
        "releaseRules": [
          { "type": "feat", "release": "minor" },
          { "type": "fix", "release": "patch" },
          { "type": "perf", "release": "patch" },
          { "type": "refactor", "release": "patch" },
          { "scope": "data", "release": false },
          { "scope": "pipeline", "release": false }
        ]
      }
    ],
    "@alexanderfortin/semantic-release-keep-a-changelog",
    [
      "@semantic-release/npm",
      {
        "npmPublish": false
      }
    ],
    [
      "@semantic-release/exec",
      {
        "publishCmd": "node -e \"const fs=require('fs'); const p=require('./site/package.json'); p.version='${nextRelease.version}'; fs.writeFileSync('./site/package.json', JSON.stringify(p, null, '\t') + '\n');\""
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "site/package.json", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    [
      "@semantic-release/github",
      {
        "successComment": false
      }
    ]
  ],
  "tagFormat": "v${version}",
  "npmPublish": false
}
