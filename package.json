{
  "name": "awesome-pi-coding-agent",
  "version": "0.1.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "seed": "bun run src/index.ts seed",
    "discover": "bun run src/index.ts discover",
    "enrich": "bun run src/index.ts enrich",
    "generate": "bun run src/index.ts generate",
    "pipeline": "bun run src/index.ts pipeline",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint",
    "test": "bun test",
    "clean": "git rm -rf data/skills/ data/extensions/ data/providers/ data/templates/ data/themes/ data/tools data/videos"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "bun-types": "1.3.13"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
