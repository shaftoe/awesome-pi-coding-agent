---
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import type { CategorizedEntry, Category } from "../lib/data";
import { CATEGORY_META, displayName, getCategories, loadAllEntries, popularity } from "../lib/data";
// biome-ignore lint/correctness/noUnusedImports: used in Astro template
import { language, lastUpdated, popularityValue, timeAgo } from "../lib/format";

export function getStaticPaths() {
	const entries = loadAllEntries();
	const categories = getCategories(entries);
	return categories.map((cat) => ({
		params: { slug: cat.href.replace("/", "") },
		props: { category: cat },
	}));
}

const { category } = Astro.props;
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const meta = CATEGORY_META[category.slug as Category];

// Pre-compute card data to avoid complex expressions in template
// biome-ignore lint/correctness/noUnusedVariables: used in Astro template
const cards = category.entries.map((entry) => ({
	name: displayName(entry),
	desc: entry.description || entry.name || entry.id,
	url: entry.url,
	pop: popularity(entry),
	popValue: popularityValue(entry),
	lastCommit: lastUpdated(entry),
	lang: language(entry),
	healthLevel: entry.health.level,
}));
---

<StarlightPage frontmatter={{ title: "", toc: false }} hasSidebar={true}>
  <a href="/" class="back-link">← All categories</a>

  <div class="category-header">
    <span class="icon">{meta.icon}</span>
    <h1>{meta.title}</h1>
    <span class="count">{category.entries.length} entries</span>
  </div>
  <p class="category-desc">{meta.description}</p>

  <category-search class="search-box">
    <input type="search" placeholder={`Filter ${category.entries.length} ${meta.title.toLowerCase()}…`} />
    <span class="search-count"></span>
  </category-search>

  <div class="entry-grid">
    {cards.map((card) => (
      <a href={card.url} target="_blank" rel="noopener noreferrer" class="entry-card" data-searchable={`${card.name} ${card.desc} ${card.lang ?? ''}`}>
        <div style="display:flex;align-items:center;gap:0.5rem">
          <h3>{card.name}</h3>
          <span class={`health-badge health-${card.healthLevel}`}>
            <span class="dot" />
            {card.healthLevel}
          </span>
        </div>
        <p class="desc">{card.desc}</p>
        <div class="meta">
          {card.pop && <span>{card.pop}</span>}
          {card.lang && (
            <span>
              <span class="lang-dot" /> {card.lang}
            </span>
          )}
          {card.lastCommit && <span class="updated">{timeAgo(card.lastCommit)}</span>}
        </div>
      </a>
    ))}
  </div>
<script>
	class CategorySearch extends HTMLElement {
		connectedCallback() {
			const input = this.querySelector<HTMLInputElement>('input[type="search"]')!;
			const countEl = this.querySelector<HTMLElement>('.search-count')!;
			const grid = this.nextElementSibling as HTMLElement;
			if (!grid || !grid.classList.contains('entry-grid')) return;

			const cards = Array.from(grid.querySelectorAll<HTMLElement>('.entry-card'));
			const total = cards.length;

			const filter = () => {
				const q = input.value.toLowerCase().trim();
				const terms = q ? q.split(/\s+/).filter(Boolean) : [];
				let visible = 0;
				for (const card of cards) {
					const text = (card.dataset.searchable ?? '').toLowerCase();
					const match = terms.length === 0 || terms.every((t) => text.includes(t));
					card.style.display = match ? '' : 'none';
					if (match) visible++;
				}
				if (terms.length > 0) {
					countEl.textContent = `${visible} of ${total}`;
				} else {
					countEl.textContent = '';
				}
			};

			input.addEventListener('input', filter);
		}
	}
	customElements.define('category-search', CategorySearch);
</script>

</StarlightPage>
